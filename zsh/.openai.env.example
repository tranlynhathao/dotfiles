# Copy this file to zsh/.openai.env and fill in your real key.
# zsh/.openai.env is git-ignored and will be sourced automatically by .zshrc
# if it exists at ~/.openai.env (via stow symlink).
#
# Get your key at: https://platform.openai.com/api-keys
export OPENAI_API_KEY="sk-proj-..."  # pragma: allowlist secret
